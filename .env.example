# =============================================================================
# Audio LLM Test Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# The platform works fully offline with Ollama + local Whisper + Edge TTS.
# API keys are only needed if you want to use paid cloud services.
# =============================================================================

# --- Database (PostgreSQL) ---
ALT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/audio_llm_test

# --- Redis (task queue) ---
ALT_REDIS_URL=redis://localhost:6379

# --- Ollama (local LLM — required for free/local mode) ---
ALT_OLLAMA_BASE_URL=http://localhost:11434

# --- API Keys (optional — leave blank for local-only mode) ---
ALT_OPENAI_API_KEY=
ALT_GOOGLE_API_KEY=
ALT_ANTHROPIC_API_KEY=
ALT_ELEVENLABS_API_KEY=
ALT_DEEPGRAM_API_KEY=

# --- Defaults ---
ALT_DEFAULT_LLM_BACKEND=ollama:mistral
ALT_DEFAULT_STT_BACKEND=whisper:base
ALT_DEFAULT_TTS_PROVIDER=edge-tts

# --- Storage ---
ALT_AUDIO_STORAGE_PATH=storage/audio
ALT_RESULTS_STORAGE_PATH=storage/results

# --- Execution ---
ALT_MAX_CONCURRENT_WORKERS=4
ALT_DEFAULT_SAMPLE_RATE=16000
